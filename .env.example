# ---------- 应用服务器 ----------
APP_TITLE=QuantClaw Device Manager
APP_HOST=0.0.0.0
APP_PORT=8082

# ---------- PostgreSQL 数据库 ----------
PG_HOST=6.6.6.66
PG_PORT=5432
PG_USER=your_username
PG_PASSWORD=your_password
PG_NAME=your_database_name
PG_DBNAME=your_database_name
PG_POOL_MIN=2
PG_POOL_MAX=10

# ---------- Redis 缓存 ----------
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# ---------- QuantClaw 设备管理 ----------
UDP_ENABLED=true
ALLOW_INSECURE=true
HEARTBEAT_INTERVAL_SEC=60

# ---------- 微信登录 ----------
WECHAT_APPID=your_wechat_appid
WECHAT_SECRET=your_wechat_secret
WECHAT_REDIRECT_URI=your_wechat_redirect_uri

# ---------- 认证 ----------
TOKEN_EXPIRE_DAYS=30
QUERY_API_KEY=your_query_api_key

# ---------- CORS 跨域 ----------
CORS_ALLOW_ORIGINS=*

# ---------- SSH 远程管理 ----------
SSH_DEFAULT_REMOTE_PATH=/home/quant
SSH_CONNECT_TIMEOUT=10
