# ============================================================
# QuantClaw 设备管理后台 - 环境配置示例
# 复制此文件为 .env 并修改相应的值
# ============================================================

# ---------- 应用服务器 ----------
APP_TITLE=QuantClaw Device Manager
APP_HOST=0.0.0.0
APP_PORT=8082

# ---------- PostgreSQL 数据库 ----------
PG_HOST=localhost
PG_PORT=5433
PG_USER=quant
PG_PASSWORD=open123456
PG_NAME=quantclaw
PG_DBNAME=quantclaw
PG_POOL_MIN=2
PG_POOL_MAX=10

# ---------- Redis 缓存 ----------
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# ---------- QuantClaw 设备管理 ----------
UDP_ENABLED=true
ALLOW_INSECURE=true
HEARTBEAT_INTERVAL_SEC=60

# ---------- 认证 ----------
TOKEN_EXPIRE_DAYS=30
QUERY_API_KEY=123quant-speed

# ---------- CORS 跨域 ----------
CORS_ALLOW_ORIGINS=*

# ---------- SSH 远程管理 ----------
SSH_DEFAULT_REMOTE_PATH=/home/quant
SSH_CONNECT_TIMEOUT=10
SSH_SUDO_TIMEOUT=30
